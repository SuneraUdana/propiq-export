# PropIQ — Environment Variables (copy to .env, never commit .env)

# Database (default: SQLite, change to PostgreSQL for production)
DATABASE_URL=sqlite:///data/propiq.db
# DATABASE_URL=postgresql://user:password@localhost:5432/propiq

# Scraper
SCRAPER_MODE=simulate          # simulate | scrape
RATE_LIMIT_SEC=1.2
PROXY_URL=                     # optional: http://user:pass@proxy:port

# OpenAI (optional — for generative chatbot upgrade)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Notifications (optional)
SENDGRID_API_KEY=
ALERT_EMAIL=you@example.com
SLACK_WEBHOOK_URL=

# Google Maps (optional — for real satellite NDVI tiles)
GOOGLE_MAPS_API_KEY=
